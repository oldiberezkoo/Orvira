# Telegram
BOT_TOKEN=

# Neon PostgreSQL
DATABASE_URL=

# Upstash Redis (session store)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=

# Google (Service Account JSON path or base64)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Or for Neon/Vercel: GOOGLE_CREDENTIALS_BASE64=<base64 of JSON>

# Google Sheets
SHEETS_SPREADSHEET_ID=
SHEETS_SHEET_NAME=Отзывы

# Google Cloud Storage (GCS)
GCS_BUCKET=your-bucket-name
GCS_PROJECT_ID=your-project-id

# Google Drive (Deprecated - now using GCS)
# DRIVE_SHARED_FOLDER_ID=
